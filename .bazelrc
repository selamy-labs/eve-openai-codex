common --enable_bzlmod
test --test_output=errors
test --test_summary=terse

# Shared remote cache and BES. CI supplies the API key at invocation time.
build:buildbuddy --bes_results_url=https://selamy-labs.buildbuddy.io/invocation/
build:buildbuddy --bes_backend=grpcs://selamy-labs.buildbuddy.io
build:buildbuddy --remote_cache=grpcs://selamy-labs.buildbuddy.io
build:buildbuddy --remote_timeout=10m
build:buildbuddy --remote_local_fallback
build:buildbuddy --remote_upload_local_results
build:buildbuddy --remote_cache_compression
build:buildbuddy --bes_upload_mode=fully_async
build:buildbuddy-ro --config=buildbuddy
build:buildbuddy-ro --remote_upload_local_results=false

try-import %workspace%/.bazelrc.local
